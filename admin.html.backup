<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard — Rent Me Bangkok</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
:root{
  --bg:#070709;--bg2:#0f0f12;--bg3:#17171c;
  --fg:#f5f5f5;--muted:#888;
  --red:#e63946;--blue:#2563eb;--blue-l:#60a5fa;
  --green:#4ade80;--yellow:#fbbf24;
  --border:rgba(255,255,255,.08);
  --border-blue:rgba(37,99,235,.3);
  --border-red:rgba(230,57,70,.3);
  --radius:10px;
  --ease:cubic-bezier(.16,1,.3,1);
  --font-head:'Bebas Neue',sans-serif;
  --font-body:'Inter',sans-serif;
  --sidebar:240px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--fg);font-family:var(--font-body);min-height:100vh;display:flex}
a{color:inherit;text-decoration:none}
button{cursor:pointer;border:none;background:none;font-family:var(--font-body)}
input,select,textarea{font-family:var(--font-body)}

/* ── LOGIN SCREEN ── */
#login-screen{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:9999;padding:24px}
#login-screen.hide{display:none}
.login-card{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:40px;width:100%;max-width:380px;position:relative;overflow:hidden}
.login-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--red),var(--blue))}
.login-logo{font-family:var(--font-head);font-size:1.6rem;letter-spacing:.05em;margin-bottom:4px}
.login-logo span{color:var(--red)}
.login-sub{font-size:12px;color:var(--muted);margin-bottom:32px}
.btn-login{width:100%;padding:13px;background:var(--red);color:#fff;border-radius:8px;font-size:14px;font-weight:700;letter-spacing:.04em;transition:opacity .2s}
.btn-login:hover{opacity:.85}
.login-error{font-size:12px;color:var(--red);margin-top:8px;display:none}
.login-error.show{display:block}

/* shared form elements */
.form-group{margin-bottom:16px}
label{display:block;font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px}
input[type=password],input[type=text],input[type=email],input[type=tel],input[type=date],input[type=number],select,textarea{
  width:100%;padding:11px 14px;background:var(--bg3);border:1px solid var(--border);
  border-radius:8px;color:var(--fg);font-size:14px;transition:border-color .2s;
}
input:focus,select:focus,textarea:focus{outline:none;border-color:var(--blue)}
input::placeholder,textarea::placeholder{color:var(--muted)}
select option{background:var(--bg2)}
textarea{resize:vertical;min-height:80px}

/* ── SIDEBAR ── */
#sidebar{width:var(--sidebar);background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;min-height:100vh;flex-shrink:0;position:fixed;top:0;left:0;bottom:0;z-index:40}
.sidebar-logo{padding:24px 20px;border-bottom:1px solid var(--border)}
.sidebar-logo-text{font-family:var(--font-head);font-size:1.1rem;letter-spacing:.06em}
.sidebar-logo-text span{color:var(--red)}
.sidebar-logo-sub{font-size:10px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-top:3px}
.sidebar-nav{padding:16px 12px;flex:1;display:flex;flex-direction:column;gap:2px}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;font-size:13px;font-weight:500;color:var(--muted);cursor:pointer;transition:all .2s}
.nav-item:hover{background:rgba(255,255,255,.05);color:var(--fg)}
.nav-item.active{background:rgba(37,99,235,.1);color:var(--blue-l);border:1px solid var(--border-blue)}
.sidebar-bottom{padding:16px 12px;border-top:1px solid var(--border)}
.sidebar-user{font-size:11px;color:var(--muted);margin-bottom:10px}
.btn-logout{width:100%;padding:9px;border:1px solid var(--border-red);color:var(--red);border-radius:8px;font-size:12px;font-weight:600;transition:background .2s}
.btn-logout:hover{background:rgba(230,57,70,.1)}

/* ── MAIN ── */
#main{margin-left:var(--sidebar);flex:1;min-height:100vh;display:flex;flex-direction:column}
.topbar{padding:16px 32px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:rgba(7,7,9,.8);backdrop-filter:blur(12px);position:sticky;top:0;z-index:30}
.topbar-title{font-family:var(--font-head);font-size:1.5rem;letter-spacing:.04em}
.topbar-date{font-size:12px;color:var(--muted)}
.content{padding:28px 32px;flex:1}

/* ── TABS ── */
.tab-panel{display:none}
.tab-panel.active{display:block;animation:fadeUp .3s var(--ease) both}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ── STAT CARDS ── */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px}
.stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:20px 22px;position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.stat-card.blue::before{background:var(--blue)}
.stat-card.red::before{background:var(--red)}
.stat-card.green::before{background:var(--green)}
.stat-card.yellow::before{background:var(--yellow)}
.stat-label{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px}
.stat-value{font-family:var(--font-head);font-size:2.4rem;color:var(--fg);line-height:1}
.stat-sub{font-size:11px;color:var(--muted);margin-top:4px}

/* ── SECTION ── */
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:12px}
.section-title{font-family:var(--font-head);font-size:1.2rem;letter-spacing:.04em}

/* ── FILTERS ── */
.filters{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px}
.filters input,.filters select{padding:8px 12px;font-size:12px;border-radius:8px;flex:1;min-width:120px}
.filters input{min-width:200px}

/* ── TABLE ── */
.table-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:12px;overflow:hidden;overflow-x:auto}
.data-table{width:100%;border-collapse:collapse;min-width:800px}
.data-table th{padding:12px 14px;text-align:left;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;border-bottom:1px solid var(--border);background:var(--bg3);white-space:nowrap}
.data-table td{padding:12px 14px;font-size:13px;border-bottom:1px solid rgba(255,255,255,.04);vertical-align:middle}
.data-table tr:last-child td{border:none}
.data-table tr:hover td{background:rgba(255,255,255,.02)}
.booking-ref-cell{font-size:11px;font-weight:700;color:var(--blue-l);letter-spacing:.08em;font-family:monospace}
.table-name{font-weight:600}
.table-meta{font-size:11px;color:var(--muted)}
.table-empty{text-align:center;padding:48px;color:var(--muted);font-size:13px}

/* ── BADGES ── */
.badge{padding:3px 9px;border-radius:100px;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;display:inline-block}
.badge-confirmed{background:rgba(74,222,128,.1);border:1px solid rgba(74,222,128,.3);color:var(--green)}
.badge-pending{background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.3);color:var(--yellow)}
.badge-cancelled{background:rgba(230,57,70,.1);border:1px solid var(--border-red);color:var(--red)}
.badge-studio{background:rgba(230,57,70,.1);color:var(--red);border:1px solid var(--border-red)}
.badge-podcast{background:rgba(37,99,235,.1);color:var(--blue-l);border:1px solid var(--border-blue)}
.badge-equipment{background:rgba(74,222,128,.1);color:var(--green);border:1px solid rgba(74,222,128,.3)}

/* ── ACTION BUTTONS ── */
.action-btn{padding:5px 10px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;transition:all .2s;border:1px solid transparent;background:none}
.action-btn.edit{border-color:var(--border-blue);color:var(--blue-l)}
.action-btn.edit:hover{background:rgba(37,99,235,.1)}
.action-btn.cancel{border-color:var(--border-red);color:var(--red)}
.action-btn.cancel:hover{background:rgba(230,57,70,.1)}
.action-btn.note{border-color:var(--border);color:var(--muted)}
.action-btn.note:hover{background:rgba(255,255,255,.05);color:var(--fg)}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:1000;display:none;align-items:center;justify-content:center;padding:24px}
.modal-overlay.show{display:flex;animation:fadeIn .2s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.modal{background:var(--bg2);border:1px solid var(--border);border-radius:16px;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;position:relative}
.modal::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--red),var(--blue));border-radius:16px 16px 0 0}
.modal-header{padding:24px 28px 0;display:flex;align-items:center;justify-content:space-between}
.modal-title{font-family:var(--font-head);font-size:1.3rem;letter-spacing:.04em}
.modal-close{width:30px;height:30px;border-radius:50%;border:1px solid var(--border);color:var(--muted);display:flex;align-items:center;justify-content:center;font-size:1.1rem;cursor:pointer;transition:.2s}
.modal-close:hover{border-color:var(--red);color:var(--red)}
.modal-body{padding:24px 28px 28px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}

/* ── BUTTONS ── */
.btn-primary{background:var(--blue);color:#fff;padding:11px 22px;border-radius:8px;font-size:13px;font-weight:700;transition:opacity .2s;cursor:pointer;border:none}
.btn-primary:hover{opacity:.85}
.btn-primary:disabled{opacity:.4;cursor:not-allowed}
.btn-red{background:var(--red);color:#fff;padding:11px 22px;border-radius:8px;font-size:13px;font-weight:700;transition:opacity .2s;cursor:pointer;border:none}
.btn-red:hover{opacity:.85}
.btn-ghost{border:1px solid var(--border);color:var(--fg);padding:11px 18px;border-radius:8px;font-size:13px;transition:border-color .2s;background:none;cursor:pointer}
.btn-ghost:hover{border-color:rgba(255,255,255,.25)}

/* ── MSG ── */
.msg{padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:14px}
.msg.error{background:rgba(230,57,70,.1);border:1px solid var(--border-red);color:#ff6b6b}
.msg.success{background:rgba(37,99,235,.1);border:1px solid var(--border-blue);color:var(--blue-l)}

/* ── TODAY LIST ── */
.today-grid{display:flex;flex-direction:column;gap:10px}
.today-card{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:14px 18px;display:flex;align-items:center;gap:14px}
.today-time{font-family:var(--font-head);font-size:1.1rem;color:var(--fg);min-width:70px}
.today-info{flex:1}
.today-name{font-weight:600;font-size:13px}
.today-svc{font-size:11px;color:var(--muted);margin-top:2px}

/* ── ADD BOOKING FORM ── */
.add-form-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:28px;max-width:700px}
.form-section{margin-bottom:28px;padding-bottom:28px;border-bottom:1px solid var(--border)}
.form-section:last-of-type{border:none;margin:0;padding:0}
.form-section-title{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;margin-bottom:16px}

/* ── CALENDAR VIEW ── */
.cal-view-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px}
.cal-view-nav{display:flex;gap:8px}
.cal-nav-btn{padding:8px 16px;border:1px solid var(--border);border-radius:8px;color:var(--fg);font-size:13px;font-weight:500;transition:.2s;cursor:pointer;background:none}
.cal-nav-btn:hover{border-color:var(--blue-l);color:var(--blue-l)}
.cal-month-title{font-family:var(--font-head);font-size:1.5rem;letter-spacing:.04em}
.cal-grid-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:14px;overflow:hidden}
.cal-head-row{display:grid;grid-template-columns:repeat(7,1fr);border-bottom:1px solid var(--border)}
.cal-head-cell{padding:12px;text-align:center;font-size:10px;font-weight:700;color:var(--muted);letter-spacing:.1em;text-transform:uppercase}
.cal-body{display:grid;grid-template-columns:repeat(7,1fr)}
.cal-cell{min-height:90px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);padding:8px;position:relative}
.cal-cell:nth-child(7n){border-right:none}
.cal-cell.empty{background:rgba(0,0,0,.2)}
.cal-cell.today{background:rgba(37,99,235,.05)}
.cal-day-num{font-size:12px;font-weight:600;color:var(--muted);margin-bottom:4px}
.cal-cell.today .cal-day-num{color:var(--blue-l)}
.cal-event{border-radius:4px;padding:2px 6px;font-size:10px;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer}
.cal-event.studio{background:rgba(230,57,70,.15);border:1px solid var(--border-red);color:var(--red)}
.cal-event.podcast{background:rgba(37,99,235,.15);border:1px solid var(--border-blue);color:var(--blue-l)}
.cal-event.equipment{background:rgba(74,222,128,.1);border:1px solid rgba(74,222,128,.3);color:var(--green)}

/* ── SPINNER ── */
.spinner{display:inline-block;width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:6px}
@keyframes spin{to{transform:rotate(360deg)}}

@media(max-width:900px){
  :root{--sidebar:200px}
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .content{padding:20px}
}
@media(max-width:640px){
  #sidebar{display:none}
  #main{margin-left:0}
  .content{padding:16px}
  .stats-grid{grid-template-columns:1fr 1fr}
  .form-row{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- ═══ LOGIN ═══ -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">RENT<span>ME</span> BANGKOK</div>
    <div class="login-sub">Admin Dashboard — Sign in to continue</div>
    <div class="form-group">
      <label for="admin-email">Email</label>
      <input type="email" id="admin-email" placeholder="you@example.com" autocomplete="email">
    </div>
    <div class="form-group">
      <label for="admin-pass">Password</label>
      <input type="password" id="admin-pass" placeholder="Password" autocomplete="current-password" onkeydown="if(event.key==='Enter')doAdminLogin()">
    </div>
    <button class="btn-login" onclick="doAdminLogin()">Sign In</button>
    <div class="login-error" id="login-error">Incorrect login.</div>
  </div>
</div>

<!-- ═══ SIDEBAR ═══ -->
<div id="sidebar">
  <div class="sidebar-logo">
    <div class="sidebar-logo-text">RENT<span>ME</span> BKK</div>
    <div class="sidebar-logo-sub">Admin Dashboard</div>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-item active" onclick="switchTab('overview',this)">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Overview
    </div>
    <div class="nav-item" onclick="switchTab('bookings',this)">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      All Bookings
    </div>
    <div class="nav-item" onclick="switchTab('add',this)">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
      Add Booking
    </div>
    <div class="nav-item" onclick="switchTab('calendar',this)">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      Calendar
    </div>
    <div class="nav-item" onclick="switchTab('users',this);loadUsers()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      Customers
    </div>
  </nav>
  <div class="sidebar-bottom">
    <div class="sidebar-user" id="sidebar-user">—</div>
    <button class="btn-logout" style="border-color:var(--border);color:var(--muted);margin-bottom:8px" onclick="changeAdminPassword()">Change Password</button>
    <button class="btn-logout" onclick="adminLogout()">Log Out</button>
  </div>
</div>

<!-- ═══ MAIN ═══ -->
<div id="main">
  <div class="topbar">
    <div class="topbar-title" id="topbar-title">OVERVIEW</div>
    <div class="topbar-date" id="topbar-date"></div>
  </div>

  <div class="content">

    <!-- OVERVIEW -->
    <div class="tab-panel active" id="tab-overview">
      <div class="stats-grid">
        <div class="stat-card blue">
          <div class="stat-label">Total Bookings</div>
          <div class="stat-value" id="stat-total">—</div>
          <div class="stat-sub">All time</div>
        </div>
        <div class="stat-card green">
          <div class="stat-label">This Month</div>
          <div class="stat-value" id="stat-month">—</div>
          <div class="stat-sub" id="stat-month-label"></div>
        </div>
        <div class="stat-card yellow">
          <div class="stat-label">Today</div>
          <div class="stat-value" id="stat-today">—</div>
          <div class="stat-sub">Scheduled today</div>
        </div>
        <div class="stat-card red">
          <div class="stat-label">Upcoming</div>
          <div class="stat-value" id="stat-upcoming">—</div>
          <div class="stat-sub">Next 7 days</div>
        </div>
      </div>

      <div class="section-header">
        <div class="section-title">TODAY'S BOOKINGS</div>
        <span id="today-date-label" style="font-size:12px;color:var(--muted)"></span>
      </div>
      <div class="today-grid" id="today-list">
        <div style="color:var(--muted);font-size:13px;padding:24px;text-align:center">Loading…</div>
      </div>
    </div>

    <!-- ALL BOOKINGS -->
    <div class="tab-panel" id="tab-bookings">
      <div class="section-header">
        <div class="section-title">ALL BOOKINGS</div>
        <button class="btn-primary" onclick="loadAllBookings()">↻ Refresh</button>
      </div>
      <div class="filters">
        <input type="text" id="filter-search" placeholder="Search name, email, ref…" oninput="filterBookings()">
        <select id="filter-service" onchange="filterBookings()">
          <option value="">All Services</option>
          <option value="studio_rental">Studio Rental</option>
          <option value="podcast">Podcast</option>
          <option value="equipment">Equipment</option>
        </select>
        <select id="filter-status" onchange="filterBookings()">
          <option value="">All Statuses</option>
          <option value="confirmed">Confirmed</option>
          <option value="pending">Pending</option>
          <option value="cancelled">Cancelled</option>
        </select>
        <input type="date" id="filter-date-from" onchange="filterBookings()">
        <input type="date" id="filter-date-to"   onchange="filterBookings()">
      </div>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Ref</th><th>Date / Time</th><th>Client</th><th>Service</th><th>Status</th><th>Source</th><th>Actions</th>
            </tr>
          </thead>
          <tbody id="bookings-tbody">
            <tr><td colspan="7" class="table-empty">Loading…</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ADD BOOKING -->
    <div class="tab-panel" id="tab-add">
      <div class="section-header">
        <div class="section-title">ADD BOOKING (PHONE / WALK-IN)</div>
      </div>
      <div class="add-form-wrap">
        <div class="msg" id="add-msg" style="display:none"></div>

        <div class="form-section">
          <div class="form-section-title">Client Details</div>
          <div class="form-row">
            <div class="form-group"><label>First Name *</label><input type="text" id="a-first" placeholder="Andy"></div>
            <div class="form-group"><label>Last Name *</label><input type="text" id="a-last" placeholder="Smith"></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Phone *</label><input type="tel" id="a-phone" placeholder="+66 81 234 5678"></div>
            <div class="form-group"><label>Email</label><input type="email" id="a-email" placeholder="client@email.com"></div>
          </div>
        </div>

        <div class="form-section">
          <div class="form-section-title">Booking Details</div>
          <div class="form-row">
            <div class="form-group">
              <label>Service *</label>
              <select id="a-service" onchange="updateAddForm()">
                <option value="">Select service…</option>
                <option value="studio_rental">Photo Studio Rental</option>
                <option value="podcast">Podcast Session</option>
                <option value="equipment">Equipment Rental</option>
              </select>
            </div>
            <div class="form-group">
              <label>Sub-type</label>
              <select id="a-subtype"><option value="">N/A</option></select>
            </div>
          </div>

          <div id="add-studio-fields">
            <div class="form-row">
              <div class="form-group"><label>Date</label><input type="date" id="a-date"></div>
              <div class="form-group">
                <label>Start Time</label>
                <select id="a-start-time">
                  <option value="">Select…</option>
                  <option>09:00</option><option>10:00</option><option>11:00</option><option>12:00</option>
                  <option>13:00</option><option>14:00</option><option>15:00</option><option>16:00</option>
                  <option>17:00</option><option>18:00</option><option>19:00</option><option>20:00</option>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Duration (hours)</label>
                <select id="a-duration">
                  <option value="">Select…</option>
                  <option value="1">1 hour</option><option value="2">2 hours</option>
                  <option value="3">3 hours</option><option value="4">4 hours</option>
                  <option value="8">Full day (8h)</option>
                </select>
              </div>
              <div class="form-group"><label>Participants (podcast)</label><input type="number" id="a-participants" min="1" max="4" placeholder="1–4"></div>
            </div>
          </div>

          <div id="add-equip-fields" style="display:none">
            <div class="form-row">
              <div class="form-group"><label>Pick-up Date</label><input type="date" id="a-equip-start"></div>
              <div class="form-group"><label>Return Date</label><input type="date" id="a-equip-end"></div>
            </div>
          </div>

          <div class="form-row" style="margin-top:8px">
            <div class="form-group">
              <label>Status</label>
              <select id="a-status"><option value="confirmed">Confirmed</option><option value="pending">Pending</option></select>
            </div>
            <div class="form-group">
              <label>Source</label>
              <select id="a-source">
                <option value="phone">Phone</option><option value="instagram">Instagram</option>
                <option value="website">Website</option><option value="walk-in">Walk-in</option>
              </select>
            </div>
          </div>
        </div>

        <div class="form-section">
          <div class="form-section-title">Notes</div>
          <div class="form-group" style="margin:0"><label>Admin Notes</label><textarea id="a-notes" placeholder="Internal notes…"></textarea></div>
        </div>

        <div style="display:flex;gap:12px;margin-top:24px">
          <button class="btn-primary" onclick="addBooking()">Add Booking</button>
          <button class="btn-ghost" onclick="resetAddForm()">Clear</button>
        </div>
      </div>
    </div>

    <!-- CALENDAR -->
    <div class="tab-panel" id="tab-calendar">
      <div class="cal-view-header">
        <div class="cal-month-title" id="cal-month-display"></div>
        <div class="cal-view-nav">
          <button class="cal-nav-btn" onclick="calViewNav(-1)">‹ Prev</button>
          <button class="cal-nav-btn" onclick="calViewNav(0)" style="border-color:var(--border-blue);color:var(--blue-l)">Today</button>
          <button class="cal-nav-btn" onclick="calViewNav(1)">Next ›</button>
        </div>
      </div>
      <div class="cal-grid-wrap">
        <div class="cal-head-row">
          <div class="cal-head-cell">Sun</div><div class="cal-head-cell">Mon</div><div class="cal-head-cell">Tue</div>
          <div class="cal-head-cell">Wed</div><div class="cal-head-cell">Thu</div><div class="cal-head-cell">Fri</div><div class="cal-head-cell">Sat</div>
        </div>
        <div class="cal-body" id="cal-body"></div>
      </div>
      <div style="display:flex;gap:16px;margin-top:12px;flex-wrap:wrap">
        <div style="display:flex;align-items:center;gap:6px;font-size:11px;color:var(--muted)"><div style="width:10px;height:10px;border-radius:2px;background:rgba(230,57,70,.2);border:1px solid var(--border-red)"></div> Studio</div>
        <div style="display:flex;align-items:center;gap:6px;font-size:11px;color:var(--muted)"><div style="width:10px;height:10px;border-radius:2px;background:rgba(37,99,235,.2);border:1px solid var(--border-blue)"></div> Podcast</div>
        <div style="display:flex;align-items:center;gap:6px;font-size:11px;color:var(--muted)"><div style="width:10px;height:10px;border-radius:2px;background:rgba(74,222,128,.1);border:1px solid rgba(74,222,128,.3)"></div> Equipment</div>
      </div>
    </div>

    <!-- USERS TAB -->
    <div class="tab-panel" id="tab-users">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px">
        <div>
          <div style="font-family:var(--font-head);font-size:1.6rem;letter-spacing:.04em">CUSTOMERS</div>
          <div style="font-size:12px;color:var(--muted);margin-top:2px">All registered accounts</div>
        </div>
        <div style="background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:8px 16px;font-size:12px;color:var(--muted)">
          Total: <strong id="users-count" style="color:var(--fg)">—</strong>
        </div>
      </div>

      <div style="background:var(--bg2);border:1px solid var(--border);border-radius:12px;overflow:hidden">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr 120px 80px;gap:0;border-bottom:1px solid var(--border);padding:10px 20px">
          <div style="font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.08em;text-transform:uppercase">Name</div>
          <div style="font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.08em;text-transform:uppercase">Email</div>
          <div style="font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.08em;text-transform:uppercase">Phone</div>
          <div style="font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.08em;text-transform:uppercase">Joined</div>
          <div style="font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.08em;text-transform:uppercase">Bookings</div>
        </div>
        <div id="users-list">
          <div style="padding:48px;text-align:center;color:var(--muted);font-size:13px">Loading customers…</div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- ═══ EDIT MODAL ═══ -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">EDIT BOOKING</div>
      <div class="modal-close" onclick="closeModal('edit-modal')">×</div>
    </div>
    <div class="modal-body">
      <div class="msg" id="edit-msg" style="display:none"></div>
      <input type="hidden" id="edit-id">
      <div class="form-row">
        <div class="form-group"><label>Booking Date</label><input type="date" id="edit-date"></div>
        <div class="form-group">
          <label>Start Time</label>
          <select id="edit-start-time">
            <option value="">—</option>
            <option>09:00</option><option>10:00</option><option>11:00</option><option>12:00</option>
            <option>13:00</option><option>14:00</option><option>15:00</option><option>16:00</option>
            <option>17:00</option><option>18:00</option><option>19:00</option><option>20:00</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Duration (hours)</label><input type="number" id="edit-duration" min="1" max="12"></div>
        <div class="form-group">
          <label>Status</label>
          <select id="edit-status">
            <option value="confirmed">Confirmed</option>
            <option value="pending">Pending</option>
            <option value="cancelled">Cancelled</option>
          </select>
        </div>
      </div>
      <div class="form-group"><label>Admin Notes</label><textarea id="edit-admin-notes" rows="3" placeholder="Internal notes…"></textarea></div>
      <div style="display:flex;gap:10px">
        <button class="btn-primary" onclick="saveEdit()">Save Changes</button>
        <button class="btn-ghost" onclick="closeModal('edit-modal')">Cancel</button>
      </div>
    </div>
  </div>
</div>

<!-- ═══ NOTE MODAL ═══ -->
<div class="modal-overlay" id="note-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">ADD / EDIT NOTE</div>
      <div class="modal-close" onclick="closeModal('note-modal')">×</div>
    </div>
    <div class="modal-body">
      <input type="hidden" id="note-id">
      <div class="form-group"><label>Admin Note</label><textarea id="note-text" rows="4" placeholder="Enter note…"></textarea></div>
      <div style="display:flex;gap:10px">
        <button class="btn-primary" onclick="saveNote()">Save Note</button>
        <button class="btn-ghost" onclick="closeModal('note-modal')">Cancel</button>
      </div>
    </div>
  </div>
</div>

<!-- ═══ CANCEL MODAL ═══ -->
<div class="modal-overlay" id="cancel-modal">
  <div class="modal" style="max-width:420px">
    <div class="modal-header">
      <div class="modal-title">CANCEL BOOKING</div>
      <div class="modal-close" onclick="closeModal('cancel-modal')">×</div>
    </div>
    <div class="modal-body">
      <input type="hidden" id="cancel-id">
      <p style="font-size:14px;color:var(--muted);margin-bottom:20px">Are you sure you want to cancel this booking? The status will be set to cancelled.</p>
      <div style="display:flex;gap:10px">
        <button class="btn-red" onclick="doCancel()">Yes, Cancel Booking</button>
        <button class="btn-ghost" onclick="closeModal('cancel-modal')">Keep Booking</button>
      </div>
    </div>
  </div>
</div>

<script>
const { createClient } = supabase;
const sb = createClient(
  'https://nghsyxwhczvwaorssgoh.supabase.co',
  'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5naHN5eHdoY3p2d2FvcnNzZ29oIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIwNDA3NDIsImV4cCI6MjA5NzYxNjc0Mn0.3EV00ggHV5domLBbJpTrdIiWatOyhNpFVJo42FqppPk'
);

let allBookings = [], filteredBookings = [];
let calViewDate = new Date();

// ── LOGIN (Supabase Auth + admin check) ──
function showLoginError(msg) {
  const el = document.getElementById('login-error');
  el.textContent = msg || 'Incorrect login.';
  el.classList.add('show');
}

async function doAdminLogin() {
  const email = document.getElementById('admin-email').value.trim();
  const password = document.getElementById('admin-pass').value;
  document.getElementById('login-error').classList.remove('show');

  const { data, error } = await sb.auth.signInWithPassword({ email, password });
  if (error || !data.session) {
    showLoginError('Incorrect email or password.');
    document.getElementById('admin-pass').value = '';
    return;
  }
  await enterIfAdmin();
}

// Verify the logged-in user is flagged is_admin in profiles
async function enterIfAdmin() {
  const { data: { user } } = await sb.auth.getUser();
  if (!user) { showLoginError('Not signed in.'); return false; }

  const { data: profile } = await sb.from('profiles')
    .select('is_admin').eq('id', user.id).maybeSingle();

  if (!profile || !profile.is_admin) {
    showLoginError('This account is not an admin.');
    await sb.auth.signOut();
    return false;
  }

  document.getElementById('sidebar-user').textContent = user.email;
  document.getElementById('login-screen').classList.add('hide');
  init();
  return true;
}

async function adminLogout() {
  await sb.auth.signOut();
  location.reload();
}

async function changeAdminPassword() {
  const pw1 = prompt('Enter your new password (min 6 characters):');
  if (pw1 === null) return;
  if (pw1.length < 6) { alert('Password must be at least 6 characters.'); return; }
  const pw2 = prompt('Confirm your new password:');
  if (pw2 === null) return;
  if (pw1 !== pw2) { alert('Passwords do not match.'); return; }

  const { error } = await sb.auth.updateUser({ password: pw1 });
  if (error) { alert('Error: ' + error.message); return; }
  alert('Password changed successfully.');
}

// Restore an existing admin session on page load
sb.auth.getSession().then(({ data }) => {
  if (data.session) enterIfAdmin();
});

// ── INIT ──
function init() {
  const now = new Date();
  document.getElementById('topbar-date').textContent = now.toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  document.getElementById('today-date-label').textContent = now.toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long'});
  const today = now.toISOString().split('T')[0];
  ['a-date','a-equip-start','a-equip-end'].forEach(id => document.getElementById(id).min = today);
  loadAllBookings();
}

// ── DATA ──
async function loadAllBookings() {
  // First try authenticated read; fall back to anon with broad policy
  const { data, error } = await sb.from('bookings').select('*').order('created_at',{ascending:false});
  if (error) { console.warn('Supabase read error:', error.message); allBookings = []; }
  else allBookings = data || [];

  // Resolve customer details for logged-in bookings (which store user_id, not guest_*)
  const { data: profiles } = await sb.from('profiles').select('*');
  const pMap = {};
  (profiles || []).forEach(p => { pMap[p.id] = p; });
  allBookings.forEach(b => {
    if (!b.guest_name && b.user_id && pMap[b.user_id]) {
      const p = pMap[b.user_id];
      b.guest_name  = `${p.first_name || ''} ${p.last_name || ''}`.trim() || '—';
      b.guest_email = b.guest_email || p.email || '';
      b.guest_phone = b.guest_phone || p.phone || '';
    }
  });

  filteredBookings = [...allBookings];
  renderStats();
  renderTodayList();
  renderTable();
  renderCalendar();
}

// ── STATS ──
const SVC_NAMES = { studio_rental:'Studio Rental', podcast:'Podcast', equipment:'Equipment' };

function renderStats() {
  const today = new Date().toISOString().split('T')[0];
  const now   = new Date();
  const month = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0');
  const next7 = new Date(now); next7.setDate(next7.getDate()+7);
  const next7s = next7.toISOString().split('T')[0];

  document.getElementById('stat-total').textContent = allBookings.length;
  document.getElementById('stat-month').textContent = allBookings.filter(b => {
    const d = b.booking_date || b.equipment_start_date || b.created_at.slice(0,10);
    return d.startsWith(month);
  }).length;
  document.getElementById('stat-month-label').textContent = now.toLocaleDateString('en-GB',{month:'long'});
  document.getElementById('stat-today').textContent = allBookings.filter(b =>
    (b.booking_date === today || b.equipment_start_date === today)
  ).length;
  document.getElementById('stat-upcoming').textContent = allBookings.filter(b => {
    const d = b.booking_date || b.equipment_start_date;
    return d && d > today && d <= next7s && b.status !== 'cancelled';
  }).length;
}

// ── TODAY ──
function renderTodayList() {
  const today = new Date().toISOString().split('T')[0];
  const items = allBookings.filter(b => b.booking_date === today && b.status !== 'cancelled')
    .sort((a,b) => (a.start_time||'').localeCompare(b.start_time||''));
  const list = document.getElementById('today-list');
  if (!items.length) {
    list.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:24px;text-align:center">No bookings today.</div>';
    return;
  }
  list.innerHTML = items.map(b => `
    <div class="today-card">
      <div class="today-time">${b.start_time||'—'}</div>
      <div class="today-info">
        <div class="today-name">${b.guest_name||'—'}</div>
        <div class="today-svc">${SVC_NAMES[b.service_type]||b.service_type}${b.duration_hours?' · '+b.duration_hours+'h':''} · ${b.guest_phone||''}</div>
      </div>
      <span class="badge badge-${b.status||'confirmed'}">${b.status||'confirmed'}</span>
    </div>`).join('');
}

// ── TABLE ──
function renderTable() {
  const tbody = document.getElementById('bookings-tbody');
  if (!filteredBookings.length) {
    tbody.innerHTML = '<tr><td colspan="7" class="table-empty">No bookings found.</td></tr>';
    return;
  }
  tbody.innerHTML = filteredBookings.map(b => {
    const date = b.booking_date
      ? new Date(b.booking_date+'T12:00').toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})
      : b.equipment_start_date
        ? new Date(b.equipment_start_date+'T12:00').toLocaleDateString('en-GB',{day:'numeric',month:'short'})
          + ' → ' + new Date(b.equipment_end_date+'T12:00').toLocaleDateString('en-GB',{day:'numeric',month:'short'})
        : '—';
    const time   = b.start_time ? b.start_time + (b.end_time ? '–'+b.end_time : '') : '';
    const cls    = b.service_type === 'studio_rental' ? 'studio' : b.service_type === 'podcast' ? 'podcast' : 'equipment';
    const status = b.status || 'confirmed';
    return `<tr>
      <td><div class="booking-ref-cell">${b.booking_ref||'—'}</div></td>
      <td><div>${date}</div><div class="table-meta">${time}</div></td>
      <td><div class="table-name">${b.guest_name||'—'}</div><div class="table-meta">${b.guest_email||''}</div><div class="table-meta">${b.guest_phone||''}</div></td>
      <td><span class="badge badge-${cls}">${SVC_NAMES[b.service_type]||b.service_type}</span></td>
      <td><span class="badge badge-${status}">${status}</span></td>
      <td><span style="font-size:11px;color:var(--muted)">${b.source||'website'}</span></td>
      <td><div style="display:flex;gap:5px;flex-wrap:wrap">
        <button class="action-btn edit"   onclick="openEdit('${b.id}')">Edit</button>
        ${status !== 'cancelled' ? `<button class="action-btn cancel" onclick="openCancel('${b.id}')">Cancel</button>` : ''}
        <button class="action-btn note"   onclick="openNote('${b.id}')">Note</button>
      </div></td>
    </tr>`;
  }).join('');
}

function filterBookings() {
  const q    = document.getElementById('filter-search').value.toLowerCase();
  const svc  = document.getElementById('filter-service').value;
  const stat = document.getElementById('filter-status').value;
  const from = document.getElementById('filter-date-from').value;
  const to   = document.getElementById('filter-date-to').value;
  filteredBookings = allBookings.filter(b => {
    const d = b.booking_date || b.equipment_start_date || '';
    if (svc  && b.service_type !== svc)   return false;
    if (stat && b.status !== stat)         return false;
    if (from && d < from)                  return false;
    if (to   && d > to)                    return false;
    if (q && ![b.guest_name,b.guest_email,b.guest_phone,b.booking_ref].join(' ').toLowerCase().includes(q)) return false;
    return true;
  });
  renderTable();
}

// ── EDIT MODAL ──
function openEdit(id) {
  const b = allBookings.find(x => x.id === id);
  if (!b) return;
  document.getElementById('edit-id').value          = id;
  document.getElementById('edit-date').value        = b.booking_date || '';
  document.getElementById('edit-start-time').value  = b.start_time   || '';
  document.getElementById('edit-duration').value    = b.duration_hours || '';
  document.getElementById('edit-status').value      = b.status       || 'confirmed';
  document.getElementById('edit-admin-notes').value = b.admin_notes  || '';
  document.getElementById('edit-msg').style.display = 'none';
  openModal('edit-modal');
}

async function saveEdit() {
  const id = document.getElementById('edit-id').value;
  const dur = parseInt(document.getElementById('edit-duration').value) || null;
  const st  = document.getElementById('edit-start-time').value || null;
  const payload = {
    booking_date:   document.getElementById('edit-date').value || null,
    start_time:     st,
    end_time:       (st && dur) ? String(parseInt(st)+dur).padStart(2,'0')+':00' : null,
    duration_hours: dur,
    status:         document.getElementById('edit-status').value,
    admin_notes:    document.getElementById('edit-admin-notes').value || null
  };
  const { error } = await sb.from('bookings').update(payload).eq('id', id);
  const el = document.getElementById('edit-msg');
  el.style.display = '';
  if (error) { el.textContent = error.message; el.className = 'msg error'; }
  else {
    el.textContent = '✓ Updated.'; el.className = 'msg success';
    loadAllBookings();
    setTimeout(() => closeModal('edit-modal'), 1200);
  }
}

// ── NOTE MODAL ──
function openNote(id) {
  const b = allBookings.find(x => x.id === id);
  document.getElementById('note-id').value   = id;
  document.getElementById('note-text').value = b?.admin_notes || '';
  openModal('note-modal');
}
async function saveNote() {
  const { error } = await sb.from('bookings').update({ admin_notes: document.getElementById('note-text').value }).eq('id', document.getElementById('note-id').value);
  if (!error) { closeModal('note-modal'); loadAllBookings(); }
}

// ── CANCEL MODAL ──
function openCancel(id) { document.getElementById('cancel-id').value = id; openModal('cancel-modal'); }
async function doCancel() {
  const { error } = await sb.from('bookings').update({ status: 'cancelled' }).eq('id', document.getElementById('cancel-id').value);
  if (!error) { closeModal('cancel-modal'); loadAllBookings(); }
}

// ── MODALS ──
function openModal(id)  { document.getElementById(id).classList.add('show'); }
function closeModal(id) { document.getElementById(id).classList.remove('show'); }
document.querySelectorAll('.modal-overlay').forEach(o =>
  o.addEventListener('click', e => { if (e.target === o) o.classList.remove('show'); })
);

// ── ADD BOOKING ──
function updateAddForm() {
  const svc = document.getElementById('a-service').value;
  const sub = document.getElementById('a-subtype');
  sub.innerHTML = '<option value="">N/A</option>';
  const isEquip = svc === 'equipment';
  document.getElementById('add-studio-fields').style.display = isEquip ? 'none' : '';
  document.getElementById('add-equip-fields').style.display  = isEquip ? '' : 'none';
  if (svc === 'podcast') {
    sub.innerHTML = '<option value="">Select…</option><option value="podcast_recording">Recording Only</option><option value="podcast_editing">Recording + Editing</option>';
  } else if (svc === 'equipment') {
    sub.innerHTML = '<option value="">Select…</option><option value="pocket3">DJI Pocket 3</option><option value="neo">DJI Neo</option><option value="nano">DJI Osmo Nano</option>';
  }
}

async function addBooking() {
  const first = document.getElementById('a-first').value.trim();
  const last  = document.getElementById('a-last').value.trim();
  const phone = document.getElementById('a-phone').value.trim();
  const svc   = document.getElementById('a-service').value;
  if (!first || !last || !phone || !svc) { showAddMsg('Fill in required fields (Name, Phone, Service).','error'); return; }

  const isEquip = svc === 'equipment';
  const dur   = parseInt(document.getElementById('a-duration').value) || null;
  const st    = document.getElementById('a-start-time').value || null;
  const payload = {
    guest_name:           `${first} ${last}`,
    guest_email:          document.getElementById('a-email').value.trim() || null,
    guest_phone:          phone,
    service_type:         svc,
    service_subtype:      document.getElementById('a-subtype').value || null,
    booking_date:         !isEquip ? document.getElementById('a-date').value || null : null,
    start_time:           st,
    end_time:             (st && dur) ? String(parseInt(st)+dur).padStart(2,'0')+':00' : null,
    duration_hours:       dur,
    equipment_start_date: isEquip ? document.getElementById('a-equip-start').value || null : null,
    equipment_end_date:   isEquip ? document.getElementById('a-equip-end').value   || null : null,
    participant_count:    parseInt(document.getElementById('a-participants').value) || null,
    status:               document.getElementById('a-status').value,
    source:               document.getElementById('a-source').value,
    admin_notes:          document.getElementById('a-notes').value.trim() || null
  };
  const { error } = await sb.from('bookings').insert(payload);
  if (error) { showAddMsg(error.message, 'error'); }
  else {
    showAddMsg('✓ Booking added!', 'success');
    resetAddForm();
    loadAllBookings();
    setTimeout(() => { document.getElementById('add-msg').style.display='none'; }, 3000);
  }
}

function showAddMsg(text, type) {
  const el = document.getElementById('add-msg');
  el.textContent = text; el.className = 'msg ' + type; el.style.display = '';
}
function resetAddForm() {
  ['a-first','a-last','a-phone','a-email','a-notes'].forEach(id => document.getElementById(id).value='');
  ['a-service','a-subtype','a-start-time','a-duration'].forEach(id => document.getElementById(id).selectedIndex=0);
  ['a-date','a-equip-start','a-equip-end'].forEach(id => document.getElementById(id).value='');
  document.getElementById('a-participants').value='';
  document.getElementById('a-status').value='confirmed';
  document.getElementById('a-source').value='phone';
  updateAddForm();
}

// ── CALENDAR VIEW ──
function calViewNav(dir) {
  if (dir === 0) calViewDate = new Date();
  else calViewDate.setMonth(calViewDate.getMonth()+dir);
  renderCalendar();
}
function renderCalendar() {
  const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const year = calViewDate.getFullYear(), month = calViewDate.getMonth();
  document.getElementById('cal-month-display').textContent = MONTHS[month] + ' ' + year;
  const firstDay = new Date(year,month,1).getDay();
  const days     = new Date(year,month+1,0).getDate();
  const today    = new Date().toISOString().split('T')[0];
  const body     = document.getElementById('cal-body');
  body.innerHTML = '';
  for (let i=0;i<firstDay;i++) { const c=document.createElement('div'); c.className='cal-cell empty'; body.appendChild(c); }
  for (let d=1;d<=days;d++) {
    const ds = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const cell = document.createElement('div');
    cell.className = 'cal-cell'+(ds===today?' today':'');
    cell.innerHTML = `<div class="cal-day-num">${d}</div>`;
    allBookings.filter(b => (b.booking_date===ds||b.equipment_start_date===ds) && b.status!=='cancelled').forEach(b => {
      const cls = b.service_type==='studio_rental'?'studio':b.service_type==='podcast'?'podcast':'equipment';
      const name = (b.guest_name||'').split(' ')[0];
      const ev = document.createElement('div');
      ev.className = 'cal-event '+cls;
      ev.textContent = `${b.start_time||''} ${name}`.trim();
      ev.title = `${b.booking_ref} — ${b.guest_name} (${SVC_NAMES[b.service_type]})`;
      ev.onclick = () => openEdit(b.id);
      cell.appendChild(ev);
    });
    body.appendChild(cell);
  }
}

// ── USERS ──
async function loadUsers() {
  const list = document.getElementById('users-list');
  list.innerHTML = '<div style="padding:48px;text-align:center;color:var(--muted);font-size:13px">Loading…</div>';

  const { data: profiles, error } = await sb.from('profiles').select('*').order('created_at', { ascending: false });
  if (error || !profiles) {
    list.innerHTML = '<div style="padding:48px;text-align:center;color:var(--red);font-size:13px">Failed to load customers.</div>';
    return;
  }

  const { data: bookings } = await sb.from('bookings').select('user_id');
  const counts = {};
  (bookings || []).forEach(b => { if (b.user_id) counts[b.user_id] = (counts[b.user_id] || 0) + 1; });

  document.getElementById('users-count').textContent = profiles.length;

  if (!profiles.length) {
    list.innerHTML = '<div style="padding:48px;text-align:center;color:var(--muted);font-size:13px">No registered customers yet.</div>';
    return;
  }

  list.innerHTML = profiles.map((p, i) => `
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr 120px 80px;gap:0;padding:14px 20px;border-bottom:${i < profiles.length-1 ? '1px solid var(--border)' : 'none'};align-items:center;transition:background .15s" onmouseover="this.style.background='rgba(255,255,255,.03)'" onmouseout="this.style.background=''">
      <div style="font-size:13px;font-weight:600">${p.first_name || '—'} ${p.last_name || ''}</div>
      <div style="font-size:12px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${p.email || '—'}</div>
      <div style="font-size:12px;color:var(--muted)">${p.phone || '—'}</div>
      <div style="font-size:12px;color:var(--muted)">${p.created_at ? new Date(p.created_at).toLocaleDateString('en-GB') : '—'}</div>
      <div style="font-size:12px;text-align:center">
        <span style="background:rgba(37,99,235,.15);border:1px solid var(--border-blue);color:var(--blue-l);border-radius:6px;padding:2px 10px;font-size:11px;font-weight:700">${counts[p.id] || 0}</span>
      </div>
    </div>
  `).join('');
}

// ── TABS ──
const TAB_TITLES = { overview:'OVERVIEW', bookings:'ALL BOOKINGS', add:'ADD BOOKING', calendar:'CALENDAR', users:'CUSTOMERS' };
function switchTab(tab, el) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  if (el) el.classList.add('active');
  document.getElementById('topbar-title').textContent = TAB_TITLES[tab]||tab.toUpperCase();
}
</script>
</body>
</html>
